{
  "page_load_timeout": 15,
  "curl_timeout": 20,
  "video_detection_timeout": 45,
  "network_idle_timeout": 5,
  "headless": true,
  "viewport_width": 1920,
  "viewport_height": 1080,
  "user_agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
  "video_extensions": [".mp4", ".webm", ".ogg", ".avi", ".mov", ".wmv", ".flv", ".m4v", ".mkv", ".ts", ".m2ts"],
  "streaming_segments": [".m3u8", ".mpd", "/segment", "/chunk", "/playlist", "/manifest"],
  "min_download_size": 2048,
  "validation_chunk_size": 2097152,
  "output_dir": "./downloads",
  "default_filename": "downloaded_video.mp4",
  "verbose": false,
  "quiet": false,
  "max_retries": 3,
  "retry_backoff_factor": 1.5,
  "max_workers": 6,
  "enable_ytdlp": true,
  "ytdlp_extra_args": [],
  "force_listing": false,
  "disable_listing": false,
  "link_selector": null,
  "link_pattern": null,
  "listing_min_links": 3,
  "enable_pagination": true,
  "max_pages": 10,
  "next_selector": null,
  "next_pattern": null,
  "page_url_template": null,
  "llm_provider": null,
  "llm_model": null,
  "disable_llm": false
}
